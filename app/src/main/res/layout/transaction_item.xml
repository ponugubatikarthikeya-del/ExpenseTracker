<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginBottom="20dp"
    app:strokeWidth="0dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="10dp"
    app:rippleColor="@null"
    app:cardUseCompatPadding="false"
    app:cardBackgroundColor="@color/black"
    app:cardPreventCornerOverlap="false"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:background="@color/light_white">


        <ImageView
            android:id="@+id/dailyExpensesDesignImageButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/outline_transaction_on_24"
            android:background="@drawable/add_symbol_bg"
            android:backgroundTint="@null"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/dailyExpensesDesignCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="Food"
            android:textColor="@color/black"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/dailyExpensesDesignImageButton"
            app:layout_constraintStart_toEndOf="@id/dailyExpensesDesignImageButton"
            app:layout_constraintTop_toTopOf="@id/dailyExpensesDesignImageButton"
            app:layout_constraintVertical_bias="0.555" />

        <TextView
            android:id="@+id/dailyExpensesDesignAmountView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-$45.00"
            android:textColor="#4f4545"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginEnd="24dp"
            app:layout_constraintBottom_toBottomOf="@id/dailyExpensesDesignCategory"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.943"
            app:layout_constraintStart_toEndOf="@+id/dailyExpensesDesignCategory"
            app:layout_constraintTop_toTopOf="@id/dailyExpensesDesignCategory" />


        <ImageView
            android:id="@+id/dailyDesignArrowShow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/baseline_arrow_upward_24"
            android:background="@drawable/arrows_roundbg"
            app:tint="@color/green"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="2dp"
            app:layout_constraintStart_toEndOf="@id/dailyExpensesDesignAmountView"
           app:layout_constraintTop_toTopOf="@id/dailyExpensesDesignAmountView"
            app:layout_constraintBottom_toBottomOf="@id/dailyExpensesDesignAmountView"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>